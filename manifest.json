{
  "id": "health",
  "name": "Allergy & Health",
  "version": "1.0.0",
  "description": "Display allergy levels (pollen counts) and health risk indicators for your area using Open-Meteo Air Quality data",
  "author": "FiestaBoard Team",
  "repository": "https://github.com/Fiestaboard/fiestaboard-plugin--health",
  "documentation": "README.md",
  "icon": "heart-pulse",
  "category": "weather",
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enable Allergy & Health",
        "default": false
      },
      "latitude": {
        "type": "number",
        "title": "Latitude",
        "description": "Location latitude for health data",
        "default": 37.7749
      },
      "longitude": {
        "type": "number",
        "title": "Longitude",
        "description": "Location longitude for health data",
        "default": -122.4194
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Refresh Interval (seconds)",
        "default": 600,
        "minimum": 60
      }
    }
  },
  "env_vars": [
    {
      "name": "HEALTH_LATITUDE",
      "required": false,
      "description": "Location latitude for health data",
      "default": "37.7749"
    },
    {
      "name": "HEALTH_LONGITUDE",
      "required": false,
      "description": "Location longitude for health data",
      "default": "-122.4194"
    }
  ],
  "variables": {
    "simple": [
      "grass_pollen",
      "tree_pollen",
      "weed_pollen",
      "aqi",
      "european_aqi",
      "pm25",
      "pm10",
      "allergy_risk",
      "allergy_risk_color",
      "respiratory_risk",
      "flu_risk",
      "cough_risk",
      "formatted"
    ]
  },
  "max_lengths": {
    "grass_pollen": 5,
    "tree_pollen": 5,
    "weed_pollen": 5,
    "aqi": 3,
    "european_aqi": 3,
    "pm25": 5,
    "pm10": 5,
    "allergy_risk": 9,
    "allergy_risk_color": 4,
    "respiratory_risk": 4,
    "flu_risk": 4,
    "cough_risk": 4,
    "formatted": 22
  },
  "color_rules_schema": {
    "allergy_risk": {
      "type": "match",
      "description": "Color based on allergy risk level",
      "default_rules": [
        {
          "condition": "==",
          "value": "EXTREME",
          "color": "violet"
        },
        {
          "condition": "==",
          "value": "VERY HIGH",
          "color": "red"
        },
        {
          "condition": "==",
          "value": "HIGH",
          "color": "orange"
        },
        {
          "condition": "==",
          "value": "MODERATE",
          "color": "yellow"
        },
        {
          "condition": "==",
          "value": "LOW",
          "color": "green"
        }
      ]
    },
    "aqi": {
      "type": "threshold",
      "description": "Color based on AQI value",
      "default_rules": [
        {
          "condition": ">",
          "value": 300,
          "color": "violet"
        },
        {
          "condition": ">",
          "value": 200,
          "color": "violet"
        },
        {
          "condition": ">",
          "value": 150,
          "color": "red"
        },
        {
          "condition": ">",
          "value": 100,
          "color": "orange"
        },
        {
          "condition": ">",
          "value": 50,
          "color": "yellow"
        },
        {
          "condition": "<=",
          "value": 50,
          "color": "green"
        }
      ]
    }
  },
  "fiestaboard_version": ">=2.10.0"
}
